---
import BaseLayout from "../layouts/BaseLayout.astro";

const slug = Astro.url.searchParams.get("slug") ?? "";
---

<BaseLayout title="Torneo" description="Información del torneo de ajedrez.">
  <div class="auth-shell">
    <div class="card">
      <h1>Torneo</h1>
      <p class="subtitle">Información del torneo</p>
    </div>
  </div>
</BaseLayout>

<style>
  .auth-shell {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100dvh;
    padding: 8vh 1rem 2rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 400px;
    padding: 2.5rem 2rem;
    background: var(--panel);
    border: 1px solid var(--border);
  }

  .subtitle {
    color: var(--dim);
    margin: 0.25rem 0 0;
  }
</style>
