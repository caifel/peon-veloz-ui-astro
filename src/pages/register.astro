---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Registro" description="Formulario de registro">
  <div class="page">
    <div class="header">
      <h1>Formulario de registro</h1>
    </div>

    <form method="post" class="form" id="register-form">
      <input type="hidden" name="token" id="register-token" />

      <label>
        <span data-required>Nombres</span>
        <input type="text" name="firstName" autocomplete="given-name" required />
      </label>

      <label>
        <span data-required>Apellidos</span>
        <input type="text" name="lastName" autocomplete="family-name" required />
      </label>

      <label>
        <span data-required>Fecha de nacimiento</span>
        <input type="date" name="birthDate" id="birth-date" autocomplete="bday" required />
      </label>

      <label>
        <span data-required>Departamento</span>
        <select name="stateName" required>
          <option value="" disabled selected>Selecciona...</option>
          <option value="BN">Beni</option>
          <option value="CH">Chuquisaca</option>
          <option value="CB">Cochabamba</option>
          <option value="LP">La Paz</option>
          <option value="OR">Oruro</option>
          <option value="PD">Pando</option>
          <option value="PT">Potosí</option>
          <option value="SC">Santa Cruz</option>
          <option value="TR">Tarija</option>
        </select>
      </label>

      <a id="lichess-link" class="lichess-link" target="lichess-auth">Verificar cuenta de Lichess</a>

      <input type="hidden" id="lichess-username" name="lichessUsername" />
      <input type="hidden" id="lichess-id" name="lichessId" />
      <input type="hidden" id="email" name="email" />

      <small id="success-box" class="success-box" hidden></small>
      <small id="error-box" class="error-box" hidden></small>

      <button type="submit" class="submit">Continuar</button>
    </form>
  </div>
</BaseLayout>

<script>
  // Endpoints
  const API = 'https://salaried-zit-erased.ngrok-free.dev';
  // const API = 'http://192.168.1.42:4000';
  const LICHESS_AUTH = `${API}/api/auth/lichess`;
  const AUTH_REGISTER = `${API}/api/auth/register`;
  const REGISTER_TOKEN = `${API}/api/register`;

  // DOM
  const form = document.getElementById('register-form');
  const submitBtn = document.querySelector('.submit');
  const lichessLink = document.getElementById('lichess-link');
  const inputUsername = document.getElementById('lichess-username');
  const inputId = document.getElementById('lichess-id');
  const inputEmail = document.getElementById('email');
  const successBox = document.getElementById('success-box');
  const errorBox = document.getElementById('error-box');
  const fields = form.querySelectorAll('input:not([type=hidden]), select');

  // Helpers
  function disable(state) {
    fields.forEach((f) => (f.disabled = state));
    submitBtn.disabled = state;
  }

  function expired(status) {
    if (status !== 410) return false;
    window.location.href = '/expired';
    return true;
  }

  function validate() {
    if (!inputUsername.value || !inputId.value) {
      return 'Debes verificar tu cuenta de Lichess antes de continuar.';
    }
    return null;
  }

  // Startup
  lichessLink.href = LICHESS_AUTH;

  const token = document.getElementById('register-token');
  token.value = new URLSearchParams(location.search).get('t') ?? '';

  const today = new Date();
  today.setFullYear(today.getFullYear() - 5);
  document.getElementById('birth-date').max = today.toISOString().split('T')[0];

  (async () => {
    const res = await fetch(`${REGISTER_TOKEN}/${token.value}`);
    expired(res.status);
  })();

  // Lichess OAuth (popup → BroadcastChannel)
  const channel = new BroadcastChannel('lichess-auth');
  channel.addEventListener('message', ({ data }) => {
    const { lichessUsername, lichessId, email, isClean, isEstablished } = data;

    inputUsername.value = lichessUsername || '';
    inputId.value = lichessId || '';
    inputEmail.value = email || '';
    if (lichessLink) lichessLink.remove();

    if (!isClean) {
      errorBox.hidden = false;
      errorBox.innerHTML =
        'Tu cuenta de Lichess tiene una violación de términos de servicio. No es posible registrarse.';
    } else if (!isEstablished) {
      errorBox.hidden = false;
      errorBox.innerHTML = 'Tu cuenta de Lichess es muy reciente. Se requieren al menos 100 partidas para registrarte.';
    } else {
      successBox.hidden = false;
      successBox.innerHTML = `El usuario <strong>${lichessUsername}</strong> fue verificado correctamente.`;
      errorBox.hidden = true;
    }
  });

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const error = validate();

    if (error) {
      errorBox.hidden = false;
      errorBox.innerHTML = error;
      return;
    }

    const body = new FormData(form);
    disable(true);

    try {
      const res = await fetch(AUTH_REGISTER, { method: 'POST', body });

      if (!res.ok) {
        if (expired(res.status)) return;
        throw new Error(await res.text());
      }
      window.location.href = res.url || '/';
    } catch (err) {
      errorBox.hidden = false;
      errorBox.innerHTML = err?.message || 'Error al enviar el registro. Intenta de nuevo.';
      disable(false);
    }
  });
</script>

<style is:global>
  .page {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  .header {
    background: var(--panel);
    height: var(--height-control);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .form {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    max-width: 500px;
    padding: 0 2rem;
  }

  .form label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-weight: 300;
    color: var(--light);
  }

  .form input,
  .form select {
    width: 100%;
  }

  .submit {
    font-family: monospace;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    width: 100vw;
    height: var(--height-control);
    color: var(--dark);
    background: var(--white);
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-weight: bold;
    letter-spacing: 2px;
    z-index: 100;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
  }

  .lichess-link {
    color: var(--light);
    text-align: center;
    text-underline-offset: 3px;
  }

  .success-box,
  .error-box {
    margin: 0;
    padding: 0.75rem;
    border: 1px solid transparent;
  }

  .success-box:not([hidden]) {
    display: block;
    border-color: lightgreen;
  }

  .error-box:not([hidden]) {
    display: block;
    border-color: lightcoral;
  }
</style>
